# Derived data-plane receiver image with Conduktor Azure OAUTHBEARER handler
# This adds the callback handler JAR to the classpath without modifying upstream code.
#
# Jib-built images use /app/libs/ for dependency JARs — anything there is on the classpath.

ARG BASE_IMAGE=gcr.io/knative-releases/knative.dev/eventing-kafka-broker/cmd/receiver:knative-v1.22.1
FROM ${BASE_IMAGE}

COPY conduktor-azure-oauthbearer.jar /app/libs/conduktor-azure-oauthbearer.jar
